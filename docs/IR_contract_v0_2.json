{
  "contract_version": "0.2.0-as-built",
  "purpose": "Machine-readable SemanticIR contract for eval and drift detection.",
  "entity_prefixes": {
    "FN": "function",
    "AFN": "async_function",
    "MT": "method",
    "AMT": "async_method",
    "CLS": "class"
  },
  "levels": {
    "L0": {
      "format": "[TYPE ENTITY_ID @file_path:start_line]\\n<raw source>",
      "fields": ["TYPE", "ENTITY_ID", "file_path", "start_line", "raw_source"],
      "notes": [
        "Raw passthrough with entity boundary markers",
        "No semantic compression"
      ]
    },
    "L1": {
      "format": "TYPE ENTITY_ID N=<name_token> [C=<calls>] [F=<flags>] [A=<assign_count>] [B=<bases>] [#DOMAIN] [#CATE]",
      "required_fields": ["TYPE", "ENTITY_ID", "N"],
      "optional_fields": ["C", "F", "A", "B"],
      "optional_tags": ["#DOMAIN", "#CATE"],
      "field_semantics": {
        "N": "Compressed name token (always present)",
        "C": "Calls and semantic references — omitted if no calls",
        "F": "Behavioral flags (sorted, concatenated) — omitted if no flags",
        "A": "Assignment operation count — omitted if zero",
        "B": "Class base references — omitted if no bases"
      },
      "flags": {
        "A": "await encountered",
        "E": "raise encountered",
        "I": "conditional branch (if)",
        "L": "loop encountered",
        "R": "return encountered",
        "T": "try/except encountered",
        "W": "with/async with encountered",
        "X": "exception-like class"
      },
      "flag_order": "alphabetical",
      "omission_rule": "Fields with empty/zero values are omitted entirely rather than using placeholders"
    },
    "L3": {
      "format": "TYPE ENTITY_ID [#DOMAIN] #CATE",
      "required_fields": ["TYPE", "ENTITY_ID", "#CATE"],
      "optional_tags": ["#DOMAIN"],
      "field_semantics": {
        "#DOMAIN": "Uppercased module domain tag (omitted when unknown)",
        "#CATE": "Uppercased first 4 chars of module category"
      },
      "internal_only": {
        "pattern_id": "Computed and stored in ir_json for change detection, but omitted from text output (zero semantic signal at selection time)"
      }
    },
    "L2": {
      "status": "implemented-but-out-of-scope",
      "reason": "Excluded from current validation plan to avoid conflating harness quality with unresolved IR-design questions."
    }
  },
  "domain_tags": {
    "HTTP": "http",
    "AUTH": "auth",
    "CRYP": "crypto",
    "DB": "db",
    "FS": "fs",
    "CLI": "cli",
    "ASYN": "async",
    "PARS": "parse",
    "NET": "net"
  },
  "module_categories": {
    "core_logic": "CORE",
    "router": "ROUT",
    "schema": "SCHE",
    "config": "CONF",
    "compat": "COMP",
    "exceptions": "EXCE",
    "constants": "CONS",
    "tests": "TEST",
    "init": "INIT",
    "docs": "DOCS",
    "utils": "UTIL"
  },
  "canonical_preambles": {
    "L1": "tests/eval/preambles/l1_preamble.md",
    "L3": "tests/eval/preambles/l3_preamble.md"
  },
  "implementation_sources": [
    "ir/compressor.py",
    "index/locator.py",
    "ir/classifier.py",
    "ir/stable_ids.py"
  ]
}
